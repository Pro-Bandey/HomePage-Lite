{
  "manifest_version": 3,
  "name": "HomePage Lite",
  "version": "10.0",
  "description": "HomePage Pro Web Version Via iframe",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "16": "16.png",
    "32": "32.png",
    "48": "48.png",
    "64": "64.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "homepage-lite@pro-bandey.com",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
